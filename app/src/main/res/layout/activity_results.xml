<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0f3460"
        app:title="النتائج"
        app:titleTextColor="#ffffff" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213e">

        <com.google.android.material.tabs.TabItem
            android:text="الناجحة" />

        <com.google.android.material.tabs.TabItem
            android:text="الفاشلة" />

    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSuccessCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="النجاح: 0"
            android:textColor="#00ff00"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFailedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="الفشل: 0"
            android:textColor="#ff4444"
            android:textStyle="bold" />

    </LinearLayout>

    <ListView
        android:id="@+id/lvSuccess"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ListView
        android:id="@+id/lvFailed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSuccess"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="حفظ الناجحة" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveFailed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="حفظ الفاشلة" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopySuccess"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="نسخ الناجحة" />

        <!-- ✅ هذا الزر المفقود الذي سبب الخطأ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopyFailed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="نسخ الفاشلة" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetryFailed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="إعادة" />

    </LinearLayout>

</LinearLayout>
